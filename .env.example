# ============================================================
# AW Property Management — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Supabase ---
# Find these in your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Resend (Email) ---
# Create an account at resend.com, verify your domain, get API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Email address that notifications are sent FROM (must be verified in Resend)
RESEND_FROM_EMAIL=notifications@yourdomain.com
# Where to send owner/manager notifications (comma-separated)
NOTIFY_EMAIL=owner@yourdomain.com

# --- Telegram ---
# Create a bot via @BotFather on Telegram, get the token
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
# Secret token to validate incoming Telegram webhook requests
TELEGRAM_WEBHOOK_SECRET=generate-a-random-secret-string-here
