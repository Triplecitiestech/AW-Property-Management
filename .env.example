# ============================================================
# AW Property Management — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Supabase ---
# Find these in your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Resend (Email) ---
# Create an account at resend.com, verify your domain, get API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Email address that notifications are sent FROM (must be verified in Resend)
RESEND_FROM_EMAIL=notifications@yourdomain.com
# Where to send owner/manager notifications (comma-separated)
NOTIFY_EMAIL=owner@yourdomain.com

# --- Twilio (SMS) ---
# Create an account at twilio.com, buy a phone number
# Find Account SID and Auth Token in the Twilio Console dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
# Your Twilio phone number (E.164 format, e.g. +12025551234)
TWILIO_PHONE_NUMBER=+12025551234
